# These mounts are handled by autofs
# nas.home:/volume1/homes/brandon           /mnt/nas/home      nfs4    sec=krb5p,_netdev 0 0
# nas.home:/volume1/Videos                  /mnt/nas/Videos    nfs4    sec=krb5p,_netdev 0 0
